						"description": "Validation Failed",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/ValidateError"
								}
							}
						}
					}
				},
				"description": "Updates an existing problem.",
				"security": [],
				"parameters": [
					{
						"description": "The ID of the problem to update.",
						"in": "path",
						"name": "problemId",
						"required": true,
						"schema": {
							"format": "double",
							"type": "number"
						}
					}
				],
				"requestBody": {
					"description": "The updated problem data.",
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/UpdateProblemParams",
								"description": "The updated problem data."
							}
						}
					}
				}
			},
			"delete": {
				"operationId": "DeleteProblem",
				"responses": {
