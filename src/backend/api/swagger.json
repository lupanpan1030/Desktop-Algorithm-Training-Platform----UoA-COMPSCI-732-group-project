								}
							}
						}
					},
					"404": {
						"description": "Problem not found",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/NotFoundError"
								}
							}
						}
					}
				},
				"description": "Retrieves the detailed information of a specific problem by its ID.",
