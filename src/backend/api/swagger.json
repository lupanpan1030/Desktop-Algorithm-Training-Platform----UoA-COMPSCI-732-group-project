		"requestBodies": {},
		"responses": {},
		"schemas": {
			"_36_Enums.Difficulty": {
				"type": "string",
				"enum": [
					"EASY",
					"MEDIUM",
					"HARD"
				]
			},
			"Difficulty": {
				"$ref": "#/components/schemas/_36_Enums.Difficulty"
			},
			"ProblemSummary": {
				"properties": {
					"problemId": {
						"type": "number",
						"format": "double"
					},
					"title": {
						"type": "string"
					},
					"difficulty": {
						"$ref": "#/components/schemas/Difficulty"
					}
				},
				"required": [
					"problemId",
					"title",
					"difficulty"
				],
				"type": "object",
				"additionalProperties": true
			},
			"ProblemDetails": {
				"properties": {
					"problemId": {
						"type": "number",
						"format": "double"
					},
					"title": {
						"type": "string"
					},
					"difficulty": {
						"$ref": "#/components/schemas/Difficulty"
					},
					"description": {
						"type": "string"
					},
					"createdAt": {
						"type": "string"
					}
				},
				"required": [
					"problemId",
					"title",
					"difficulty",
					"description",
					"createdAt"
				],
				"type": "object",
				"additionalProperties": true
			},
			"Pick_ProblemDetails.title-or-description-or-difficulty_": {
				"properties": {
					"title": {
						"type": "string"
					},
					"description": {
						"type": "string"
					},
					"difficulty": {
						"$ref": "#/components/schemas/_36_Enums.Difficulty"
					}
				},
				"required": [
					"title",
					"description",
					"difficulty"
				],
				"type": "object",
				"description": "From T, pick a set of properties whose keys are in the union K"
			},
			"CreateProblemParams": {
				"$ref": "#/components/schemas/Pick_ProblemDetails.title-or-description-or-difficulty_"
			}
		},
		"securitySchemes": {}
	},
	"info": {
		"title": "algo-platform",
