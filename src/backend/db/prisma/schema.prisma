datasource db {
    provider = "sqlite"
    url      = "file:./dev.db"
}

generator client {
    provider = "prisma-client-js"
}

model User {
    user_id           Int                 @id @default(autoincrement())
    username          String
    email             String              @unique
    password_hash     String
    created_at        DateTime            @default(now())
    submissions       Submission[]
    submission_results SubmissionResult[]
}

model Problem {
    problem_id   Int          @id @default(autoincrement())
    title        String
    description  String
    difficulty   Difficulty
    created_at   DateTime     @default(now())
    test_cases   TestCase[]
    submissions  Submission[]
    problem_tags ProblemTag[]
}

model TestCase {
    testcase_id     Int      @id @default(autoincrement())
    input_data      String
    expected_output String
    time_limit      Int
    memory_limit    Int
    problem         Problem  @relation(fields: [problem_id], references: [problem_id])
    problem_id      Int
}

model ProgrammingLanguage {
    language_id     Int         @id @default(autoincrement())
    name            String
    suffix          String
    version         String?
    compile_command String?
    run_command     String
    submissions     Submission[]
}

model Submission {
    submission_id Int                @id @default(autoincrement())
    user          User               @relation(fields: [user_id], references: [user_id])
    user_id       Int
    problem       Problem            @relation(fields: [problem_id], references: [problem_id])
    problem_id    Int
    language      ProgrammingLanguage           @relation(fields: [language_id], references: [language_id])
    language_id   Int
    code          String
    status        SubmissionStatus
    output        String?
    submitted_at  DateTime           @default(now())
    results       SubmissionResult[]
}

model SubmissionResult {
    submission_result_id Int         @id @default(autoincrement())
    submission           Submission  @relation(fields: [submission_id], references: [submission_id])
    submission_id        Int
    user                 User        @relation(fields: [user_id], references: [user_id])
    user_id              Int
    status               SubmissionStatus
    output               String?
    runtime_ms           Int
    memory_kb            Int
    submitted_at         DateTime    @default(now())
}

model Tag {
    tag_id      Int           @id @default(autoincrement())
    name        String        @unique
    problem_tags ProblemTag[]
}

model ProblemTag {
    problem   Problem @relation(fields: [problem_id], references: [problem_id])
    problem_id Int
    tag       Tag     @relation(fields: [tag_id], references: [tag_id])
    tag_id    Int

    @@id([problem_id, tag_id])
}

enum Difficulty {
    EASY
    MEDIUM
    HARD
}

enum SubmissionStatus {
    PENDING
    ACCEPTED
    REJECTED
    TIME_LIMIT_EXCEEDED
    COMPILE_ERROR
    RUNTIME_ERROR
}
