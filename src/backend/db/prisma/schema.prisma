datasource db {
    provider = "sqlite"
    url      = env("DATABASE_URL")
}

generator client {
    provider = "prisma-client-js"
}

model Problem {
    problem_id   Int          @id @default(autoincrement())
    title        String
    description  String
    difficulty   Difficulty
    source       String       @default("LOCAL")
    source_slug  String?
    external_problem_id String?
    import_key   String?      @unique
    locale       String       @default("local")
    judge_ready  Boolean      @default(true)
    sample_testcase String?
    created_at   DateTime     @default(now())
    test_cases   TestCase[]
    submissions  Submission[]
    problem_tags ProblemTag[]
    starter_codes ProblemStarterCode[]
    translations ProblemTranslation[]

    @@index([source, locale])
}

model ProblemTranslation {
    problem_translation_id Int     @id @default(autoincrement())
    problem                Problem @relation(fields: [problem_id], references: [problem_id], onDelete: Cascade)
    problem_id             Int
    locale                 String
    title                  String
    description            String

    @@unique([problem_id, locale])
    @@index([locale])
}

model TestCase {
    testcase_id     Int      @id @default(autoincrement())
    input_data      String
    expected_output String
    time_limit_ms      Int @map("time_limit")
    memory_limit_mb    Int @map("memory_limit")
    is_sample       Boolean  @default(false)
    problem         Problem  @relation(fields: [problem_id], references: [problem_id], onDelete: Cascade)
    problem_id      Int
}

model ProgrammingLanguage {
    language_id     Int         @id @default(autoincrement())
    name            String
    normalized_name String?     @unique
    normalized_suffix String?   @unique
    suffix          String
    version         String?
    compile_command String?
    run_command     String
    /// Indicates the single default language used by the system
    is_default Boolean @default(false)
    submissions     Submission[]
}

model Submission {
    submission_id Int                @id @default(autoincrement())
    problem       Problem            @relation(fields: [problem_id], references: [problem_id], onDelete: Cascade)
    problem_id    Int
    language      ProgrammingLanguage @relation(fields: [language_id], references: [language_id], onDelete: Cascade)
    language_id   Int
    code          String
    status        SubmissionStatus
    submitted_at  DateTime           @default(now())
    results       SubmissionResult[]
}

model SubmissionResult {
    submission_result_id Int         @id @default(autoincrement())
    submission           Submission  @relation(fields: [submission_id], references: [submission_id], onDelete: Cascade)
    submission_id        Int
    status               SubmissionStatus @default(PENDING)
    output               String?
    stdout               String?
    stderr               String?
    exit_code            Int?
    phase                String?
    timed_out            Boolean     @default(false)
    runtime_ms           Int
    memory_kb            Int
    submitted_at         DateTime    @default(now())
}

model Tag {
    tag_id      Int           @id @default(autoincrement())
    name        String        @unique
    problem_tags ProblemTag[]
}

model ProblemTag {
    problem   Problem @relation(fields: [problem_id], references: [problem_id], onDelete: Cascade)
    problem_id Int
    tag       Tag     @relation(fields: [tag_id], references: [tag_id], onDelete: Cascade)
    tag_id    Int

    @@id([problem_id, tag_id])
}

model ProblemStarterCode {
    starter_code_id Int     @id @default(autoincrement())
    problem         Problem @relation(fields: [problem_id], references: [problem_id], onDelete: Cascade)
    problem_id      Int
    language_slug   String
    language_name   String
    template        String

    @@unique([problem_id, language_slug])
}

enum Difficulty {
    EASY
    MEDIUM
    HARD
}

enum SubmissionStatus {
    PENDING
    ACCEPTED
    REJECTED
    TIME_LIMIT_EXCEEDED
    COMPILE_ERROR
    RUNTIME_ERROR
}
