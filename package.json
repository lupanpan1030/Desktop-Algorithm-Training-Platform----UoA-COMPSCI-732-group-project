{
  "name": "algo-platform",
  "productName": "algo-platform",
  "version": "1.0.0",
  "description": "A local Electron-based algorithm practice platform with problem curation and judge tooling",
  "main": ".webpack/main",
  "scripts": {
    "start": "cross-env NODE_ENV=development electron-forge start",
    "start:node22": "bash ./scripts/start-dev-node.sh",
    "package": "cross-env NODE_ENV=production npx ts-node src/backend/db/prepare-package-db.ts && npx prisma generate && electron-forge package",
    "make": "cross-env NODE_ENV=production npx ts-node src/backend/db/prepare-package-db.ts && npx prisma generate && electron-forge make",
    "publish": "cross-env NODE_ENV=production npx ts-node src/backend/db/prepare-package-db.ts && npx prisma generate && electron-forge publish",
    "lint": "eslint --ext .js,.jsx,.ts,.tsx src prisma.config.ts",
    "test": "npm run test:front && npm run test:back",
    "test:front": "vitest --config=vitest.config.ts --project frontend",
    "test:back": "vitest --config=vitest.config.ts --project backend",
    "dev": "ts-node-dev --respawn src/backend/api/server.ts",
    "db:init": "npx ts-node src/backend/db/seeds/init-db_first.ts",
    "db:reset": "npx ts-node src/backend/db/seeds/init-db+drop.ts",
    "db:prepare-package-db": "npx ts-node src/backend/db/prepare-package-db.ts",
    "import:leetcode-cn": "npx ts-node src/backend/db/importers/import-leetcode-cn.ts"
  },
  "keywords": [],
  "author": {
    "name": "Chen Lu (lupanpan)",
    "email": "clu396@aucklanduni.ac.nz"
  },
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@babel/preset-env": "^7.26.9",
    "@babel/preset-react": "^7.26.3",
    "@electron-forge/cli": "^7.8.0",
    "@electron-forge/maker-deb": "^7.8.0",
    "@electron-forge/maker-rpm": "^7.8.0",
    "@electron-forge/maker-squirrel": "^7.8.0",
    "@electron-forge/maker-zip": "^7.8.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.8.0",
    "@electron-forge/plugin-fuses": "^7.8.0",
    "@electron-forge/plugin-webpack": "^7.8.0",
    "@electron/fuses": "^1.8.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.14",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vercel/webpack-asset-relocator-loader": "1.7.3",
    "@vitejs/plugin-react": "^4.4.1",
    "axios-mock-adapter": "^2.1.0",
    "babel-loader": "^10.0.0",
    "copy-webpack-plugin": "^13.0.0",
    "cross-env": "^7.0.3",
    "css-loader": "^6.11.0",
    "electron": "35.1.2",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "fork-ts-checker-webpack-plugin": "^7.3.0",
    "jsdom": "^26.1.0",
    "monaco-editor-webpack-plugin": "^7.1.0",
    "node-loader": "^2.1.0",
    "prisma": "^6.18.0",
    "sqlite3": "^5.1.7",
    "style-loader": "^3.3.4",
    "supertest": "^7.1.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.2",
